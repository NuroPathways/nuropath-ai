{
  "name": "ClientAccount",
  "type": "object",
  "properties": {
    "username": {
      "type": "string",
      "description": "Unique username e.g. jsmith-2048"
    },
    "first_name": {
      "type": "string"
    },
    "last_name": {
      "type": "string"
    },
    "phone": {
      "type": "string"
    },
    "email": {
      "type": "string",
      "description": "Real or generated email used for Base44 login"
    },
    "access_code": {
      "type": "string",
      "description": "6-character alphanumeric code used for username+code login"
    },
    "family_id": {
      "type": "string",
      "description": "ID of linked Family record"
    },
    "clinician_id": {
      "type": "string"
    },
    "account_type": {
      "type": "string",
      "enum": [
        "parent_family",
        "individual",
        "caregiver"
      ]
    },
    "invite_token": {
      "type": "string",
      "description": "Token used for RoleSetup redirect"
    },
    "is_active": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "username",
    "first_name",
    "last_name",
    "clinician_id"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "clinician_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "read": {
      "$or": [
        {
          "clinician_id": "{{user.id}}"
        },
        {
          "email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "clinician_id": "{{user.id}}"
        },
        {
          "email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "clinician_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}