{
  "name": "Message",
  "type": "object",
  "properties": {
    "from_user_id": {
      "type": "string"
    },
    "to_user_id": {
      "type": "string"
    },
    "child_id": {
      "type": "string"
    },
    "body": {
      "type": "string"
    },
    "is_read": {
      "type": "boolean",
      "default": false
    },
    "sender_role": {
      "type": "string",
      "enum": [
        "clinician",
        "parent"
      ]
    }
  },
  "required": [
    "from_user_id",
    "to_user_id",
    "body"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "from_user_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "read": {
      "$or": [
        {
          "from_user_id": "{{user.id}}"
        },
        {
          "to_user_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "to_user_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "from_user_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}